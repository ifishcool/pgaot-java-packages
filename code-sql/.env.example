# MySQL 连接地址
CODE_SQL_URL=jdbc:mysql://host:3306/db

# 数据库用户名
CODE_SQL_USER=root

# 数据库密码
CODE_SQL_PASS=password

# === 连接池参数（可选，以下为默认值）===
# CODE_SQL_POOL_INITIAL=5
# CODE_SQL_POOL_MIN_IDLE=5
# CODE_SQL_POOL_MAX_ACTIVE=20
# CODE_SQL_POOL_MAX_WAIT=60000

# === 多数据源示例 ===
# CODE_SQL_URL_MAIN=jdbc:mysql://host1:3306/main_db
# CODE_SQL_USER_MAIN=root
# CODE_SQL_PASS_MAIN=password
