# 云塔应用 ID
YUNTOWER_APP_ID=

# 云塔应用密钥
YUNTOWER_APP_SECRET=

# JWT 签名密钥（至少 32 字符）
CODE_AUTH_JWT_SECRET=

# Redis 连接地址
CODE_AUTH_REDIS_URI=redis://:密码@IP:6379/1

# Token 有效秒数（默认 604800 = 7 天）
CODE_AUTH_TOKEN_TTL=604800

# Redis Key 前缀（默认 login:token）
CODE_AUTH_KEY_PREFIX=login:token

# 数据库连接地址
CODE_SQL_URL=jdbc:mysql://host:3306/db

# 数据库用户名
CODE_SQL_USER=

# 数据库密码
CODE_SQL_PASS=
